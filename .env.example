# Copy this file to .env and fill in real values. Never commit .env itself.

# Generate one with: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=changeme

# Comma-separated list of hostnames this app is served from, e.g. orms.example.com
DJANGO_ALLOWED_HOSTS=

# Postgres connection string, e.g. postgres://user:password@localhost:5432/orms
DATABASE_URL=

# SMTP credentials for outgoing email (password reset, notifications).
# Use a Gmail App Password, never your account password.
EMAIL_HOST=smtp.gmail.com
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_PORT=587

# Set to False if TLS is terminated somewhere other than directly in front of this app.
DJANGO_SECURE_SSL_REDIRECT=True
