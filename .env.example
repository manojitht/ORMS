# Copy this file to .env and fill in real values. Never commit .env itself.

# Generate one with: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=changeme

# Comma-separated list of hostnames this app is served from, e.g. sukhra.example.com
DJANGO_ALLOWED_HOSTS=

# Postgres connection string, e.g. postgres://user:password@localhost:5432/sukhra
# Not needed if running via docker-compose — docker-compose.yml builds this
# automatically from the POSTGRES_* vars below and injects it into the app
# container. Set it directly here for a non-Docker deployment.
DATABASE_URL=

# Only used by docker-compose's `db` service (ignored otherwise).
POSTGRES_DB=sukhra
POSTGRES_USER=sukhra
POSTGRES_PASSWORD=changeme

# SMTP credentials for outgoing email (password reset, notifications).
# Use a Gmail App Password, never your account password.
EMAIL_HOST=smtp.gmail.com
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_PORT=587

# True once real TLS is terminated in front of this app (a cloud load
# balancer/CDN, or nginx extended with a real certificate). Set to False for
# local docker-compose testing with no TLS at all — otherwise every request
# redirect-loops trying to reach a HTTPS endpoint that doesn't exist yet.
DJANGO_SECURE_SSL_REDIRECT=True
